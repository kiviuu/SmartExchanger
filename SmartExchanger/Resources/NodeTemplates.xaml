<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:nodify="https://miroiu.github.io/nodify"
                    xmlns:nodes="clr-namespace:SmartExchanger.ViewModels.Nodes"
                    xmlns:helpers="clr-namespace:SmartExchanger.Helpers"
                    xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF">

    <DataTemplate DataType="{x:Type nodes:ColorNodeViewModel}">
        <nodify:Node Header="{Binding Title}" 
                     Input="{Binding Inputs}" 
                     Output="{Binding Outputs}"
                     Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=nodify:NodifyEditor}}">

            <nodify:Node.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Delete" 
                              Command="{Binding PlacementTarget.Tag.DeleteNodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                              CommandParameter="{Binding}"/>
                </ContextMenu>
            </nodify:Node.ContextMenu>

            <nodify:Node.OutputConnectorTemplate>
                <DataTemplate>
                    <nodify:NodeOutput Header="{Binding Title}" 
                                       Anchor="{Binding Anchor, Mode=OneWayToSource}" 
                                       IsConnected="{Binding IsConnected}"/>
                </DataTemplate>
            </nodify:Node.OutputConnectorTemplate>

            <StackPanel Width="180" Margin="8">
                <Border Height="40" Background="{Binding ColorBrush}" CornerRadius="4" Margin="0,0,0,8" BorderBrush="#555" BorderThickness="1"/>

                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="R" Foreground="Red" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding R, Mode=TwoWay, Delay=100}" TickFrequency="1" IsSnapToTickEnabled="True"/>
                </Grid>

                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="G" Foreground="Green" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding G, Mode=TwoWay, Delay=100}" TickFrequency="1" IsSnapToTickEnabled="True"/>
                </Grid>

                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="B" Foreground="SkyBlue" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding B, Mode=TwoWay, Delay=100}" TickFrequency="1" IsSnapToTickEnabled="True"/>
                </Grid>
            </StackPanel>
        </nodify:Node>
    </DataTemplate>

