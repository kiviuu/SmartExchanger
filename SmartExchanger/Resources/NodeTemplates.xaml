    <DataTemplate DataType="{x:Type nodes:OutputNodeViewModel}">
        <nodify:Node Header="{Binding Title}" 
                     Input="{Binding Inputs}" 
                     Output="{Binding Outputs}"
                     Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=nodify:NodifyEditor}}">

            <nodify:Node.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Delete" 
                              Command="{Binding PlacementTarget.Tag.DeleteNodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                              CommandParameter="{Binding}"/>
                </ContextMenu>
            </nodify:Node.ContextMenu>

            <nodify:Node.InputConnectorTemplate>
                <DataTemplate>
                    <nodify:NodeInput Header="{Binding Title}" 
                                      Anchor="{Binding Anchor, Mode=OneWayToSource}" 
                                      IsConnected="{Binding IsConnected}"/>
                </DataTemplate>
            </nodify:Node.InputConnectorTemplate>

            <Border Width="140" Height="140" Margin="8" Background="#00000000" CornerRadius="6" BorderBrush="#3F3F46" BorderThickness="2" ClipToBounds="True">
                <Grid Width="256" Height="256" Background="Black">
                    <skia:SKGLElement helpers:SkiaExtensions.Editor="{Binding DataContext, RelativeSource={RelativeSource AncestorType=nodify:NodifyEditor}}"
                                        helpers:SkiaExtensions.OutputNode="{Binding}"
                                        Width="256" Height="256" />

                    <TextBlock Text="NO SIGNAL" 
                                Foreground="Transparent" 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentTexture}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
        </nodify:Node>
    </DataTemplate>


    <DataTemplate DataType="{x:Type nodes:BlendNodeViewModel}">
        <nodify:Node Header="{Binding Title}" 
                     Input="{Binding Inputs}" 
                     Output="{Binding Outputs}"
                     Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=nodify:NodifyEditor}}">

            <nodify:Node.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Delete" 
                              Command="{Binding PlacementTarget.Tag.DeleteNodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                              CommandParameter="{Binding}"/>
                </ContextMenu>
            </nodify:Node.ContextMenu>

            <nodify:Node.InputConnectorTemplate>
                <DataTemplate>
                    <nodify:NodeInput Header="{Binding Title}" 
                                      Anchor="{Binding Anchor, Mode=OneWayToSource}" 
                                      IsConnected="{Binding IsConnected}"/>
                </DataTemplate>
            </nodify:Node.InputConnectorTemplate>

            <nodify:Node.OutputConnectorTemplate>
                <DataTemplate>
                    <nodify:NodeOutput Header="{Binding Title}" 
                                       Anchor="{Binding Anchor, Mode=OneWayToSource}" 
                                       IsConnected="{Binding IsConnected}"/>
                </DataTemplate>
            </nodify:Node.OutputConnectorTemplate>

            <StackPanel Width="180" Margin="8">
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Mode" FontWeight="Bold" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1"
                              Margin="10,0,0,0"
                              ItemsSource="{Binding AvailableBlendModes}"
                              SelectedItem="{Binding SelectedBlendMode}"
                              />
                </Grid>
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Factor" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Slider Margin="10 0 0 0" Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding Factor, Mode=TwoWay, Delay=150}" TickFrequency="0.001" IsSnapToTickEnabled="True"/>
                </Grid>
            </StackPanel>
        </nodify:Node>
    </DataTemplate>

    <DataTemplate DataType="{x:Type nodes:TextureSizeNodeViewModel}">
        <nodify:Node Header="{Binding Title}" 
                     Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=nodify:NodifyEditor}}">

            <nodify:Node.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Delete" 
                              Command="{Binding PlacementTarget.Tag.DeleteNodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                              CommandParameter="{Binding}"/>
                </ContextMenu>
            </nodify:Node.ContextMenu>

            <StackPanel Width="160" Margin="8">
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Size" FontWeight="Bold" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" 
                              Margin="10,0,0,0" 
                              ItemsSource="{Binding AvailableSizes}" 
                              SelectedItem="{Binding SelectedSize, Mode=TwoWay}"/>
                </Grid>
                <TextBlock Text="px (Square)" Foreground="#777" FontSize="10" Margin="60,2,0,0"/>
            </StackPanel>
        </nodify:Node>
    </DataTemplate>
</ResourceDictionary>