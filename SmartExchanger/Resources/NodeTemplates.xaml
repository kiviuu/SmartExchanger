                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Seed"  FontWeight="Bold" VerticalAlignment="Center"/>
                    <Slider Margin="10 0 0 0" Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding Seed, Mode=TwoWay, Delay=150}" TickFrequency="0.05" IsSnapToTickEnabled="True"/>
                </Grid>

                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Octaves"  FontWeight="Bold" VerticalAlignment="Center"/>
                    <Slider Margin="10 0 0 0" Grid.Column="1" Minimum="0" Maximum="5" Value="{Binding Octaves, Mode=TwoWay, Delay=150}" TickFrequency="1" IsSnapToTickEnabled="True"/>
                </Grid>
            </StackPanel>
