<UserControl x:Class="SmartExchanger.Views.MaterialPreviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hx="http://helix-toolkit.org/wpf/SharpDX">

    <Grid Background="#202020">
        <Border Background="#202020"
                BorderBrush="#383838"
                BorderThickness="1,0,0,0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#252525"
                        BorderBrush="#383838"
                        BorderThickness="0,0,0,1">
                    <Grid Margin="12,0,8,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Material Preview"
                                   VerticalAlignment="Center"
                                   Foreground="White"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0, 0, 12, 0"/>
                        <ComboBox Grid.Column="2"
                                  Height="30"
                                  VerticalAlignment="Center"
                                  ItemsSource="{Binding AvailableEnvironmentMaps}"
                                  SelectedItem="{Binding SelectedEnvironmentMap, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName" />
                    </Grid>
                </Border>
                <hx:Viewport3DX Grid.Row="1"
                                BackgroundColor="#181818"
                                Camera="{Binding Camera}"
                                EffectsManager="{Binding EffectsManager}"
                                EnableSwapChainRendering="False"
                                FXAALevel="Medium"
                                ShowCoordinateSystem="False"
                                ShowViewCube="False">
                    <hx:AmbientLight3D Color="#101010"/>
                    <hx:DirectionalLight3D Color="White" Direction="-1,-1,-2"/>

                    <hx:EnvironmentMap3D x:Name="EnvironmentMap"
                                         Texture="{Binding EnvironmentTexture}"
                                         IsRendering="True" />

                    <hx:MeshGeometryModel3D Geometry="{Binding SphereGeometry}"
                                            Material="{Binding SphereMaterial}"
                                            CullMode="Back"/>
                </hx:Viewport3DX>
            </Grid>
            
        </Border>
    </Grid>
</UserControl>